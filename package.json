{
  "name": "skillbridge-codex-hackathon",
  "version": "1.0.0",
  "description": "SkillBridge Agent: a Codex hackathon prototype for turning displaced workers' experience into verified local job pathways.",
  "type": "module",
  "scripts": {
    "start": "python -m backend.server",
    "start:dev": "DEBUG=true python -m backend.server",
    "start:prod": "ENVIRONMENT=production python -m backend.server",
    "build": "node scripts/validate.mjs",
    "build:prod": "npm run build && npm start:prod",
    "test": "python test_deployment.py",
    "test:syntax": "python -m py_compile backend/*.py",
    "docker:build": "docker build -t skillbridge:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:prod": "ENVIRONMENT=production docker-compose up -d",
    "docker:test": "docker-compose up && npm run test",
    "init:db": "python -c \"from backend import db; db.init_db(); from backend import auth; auth.ensure_demo_user()\"",
    "test:api": "curl http://localhost:5173/api/health"
  },
  "dependencies": {},
  "devDependencies": {},
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}

# Development Environment Configuration
# Used for local development - DO NOT use in production

ENVIRONMENT=development
DEBUG=true
PORT=5173
HOST=127.0.0.1

# Database
SKILLBRIDGE_DB=data/skillbridge.db
DATABASE_TIMEOUT=30

# Security (not critical in development)
JWT_SECRET=dev-secret-key-not-secure-for-production
CORS_ORIGIN=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# Authentication
SESSION_TIMEOUT_DAYS=7
PASSWORD_MIN_LENGTH=8

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/skillbridge.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# Features
ENABLE_DEMO_LOGIN=true
ENABLE_USER_REGISTRATION=true
MAX_CASES_PER_USER=1000
